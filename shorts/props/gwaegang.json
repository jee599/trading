      "startFrame": 90,
      "durationFrames": 120,
      "tts": {
        "ko": "카리스마가 무서울 정도. 말 안 해도 분위기 장악함. 조용히 서 있기만 해도 주변이 긴장함.",
        "en": "Charisma so intense it's almost scary. Controls the room without saying a word. Just standing quietly makes everyone tense.",
        "ja": "カリスマが怖いほど。何も言わなくても場を支配する。静かに立ってるだけで周りが緊張する。"
      },
      "number": 1,
      "title": "카리스마 = 무기",
      "titleAnimation": "slideInLeft",
      "icon": "crown_dark",
      "iconAnimation": "descendGlow",
      "bgEffect": "shadowGrow",
      "sfx": "bassDrop"

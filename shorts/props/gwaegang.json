    {
      "type": "emotional",
      "startFrame": 330,
      "durationFrames": 120,
      "tts": {
        "ko": "혼자 있는 시간이 필수. 사람 많은 곳에 오래 있으면 에너지가 바닥남. 충전은 무조건 혼자.",
        "en": "Alone time is essential. Too long in crowded places drains their energy completely. Recharging is always solo.",
        "ja": "一人の時間が必須。人が多い場所に長くいるとエネルギーが底をつく。充電は絶対一人。"
      },
      "number": 3,
      "title": "혼자 충전 필수 (안 하면 폭발)",
      "titleAnimation": "fadeInSlow",
      "highlightWord": "폭발",
      "highlightColor": "#FF4444",
      "icon": "battery",
      "iconAnimation": "drainToCharge",
      "bgEffect": "crowdFadeToAlone",
      "moodShift": "calm",
      "sfx": "quietAmbient"
